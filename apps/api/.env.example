NODE_ENV=development
PORT=3000

# Local PostgreSQL used by infra/local/compose.yaml.
DATABASE_URL=postgresql://visual_pipeline:visual_pipeline@localhost:5432/visual_pipeline?schema=public
DIRECT_DATABASE_URL=postgresql://visual_pipeline:visual_pipeline@localhost:5432/visual_pipeline?schema=public

# Prisma pg driver pool settings.
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=10000

# Production only: aws, gcp, or azure.
CLOUD_PROVIDER=aws
AWS_RDS_DATABASE_URL=
GCP_CLOUD_SQL_DATABASE_URL=
AZURE_POSTGRES_DATABASE_URL=

# GitHub OAuth. Callback URL must match the OAuth app setting in GitHub.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
FRONTEND_AUTH_CALLBACK_URL=http://localhost:4200/auth/callback
AUTH_OAUTH_STATE_SECRET=change-me-for-local-development
