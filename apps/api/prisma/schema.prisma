generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum AuthProvider {
  GITHUB
  GITLAB
  BITBUCKET
  LOCAL
}

enum PasswordResetStatus {
  PENDING
  USED
  EXPIRED
}

model User {
  id                String        @id @default(uuid()) @db.Uuid
  email             String        @unique @db.VarChar(320)
  displayName       String        @db.VarChar(120)
  passwordHash      String?       @db.VarChar(255)
  emailVerifiedAt   DateTime?     @db.Timestamptz(3)
  status            UserStatus    @default(ACTIVE)
  lastLoginAt       DateTime?     @db.Timestamptz(3)
  passwordChangedAt DateTime?     @db.Timestamptz(3)
  createdAt         DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime      @updatedAt @db.Timestamptz(3)
  authAccounts      AuthAccount[]
  sessions          Session[]
  passwordResets    PasswordResetToken[]

  @@index([status])
}

model AuthAccount {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @db.Uuid
  provider          AuthProvider
  providerAccountId String       @db.VarChar(255)
  username          String?      @db.VarChar(255)
  avatarUrl         String?      @db.Text
  createdAt         DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime     @updatedAt @db.Timestamptz(3)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  accessTokenHash   String    @unique @db.VarChar(128)
  refreshTokenHash  String    @unique @db.VarChar(128)
  userAgent         String?   @db.VarChar(512)
  ipAddress         String?   @db.VarChar(64)
  expiresAt         DateTime  @db.Timestamptz(3)
  refreshExpiresAt  DateTime  @db.Timestamptz(3)
  revokedAt         DateTime? @db.Timestamptz(3)
  createdAt         DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(3)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([refreshExpiresAt])
}

model PasswordResetToken {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid
  tokenHash   String              @unique @db.VarChar(128)
  status      PasswordResetStatus @default(PENDING)
  expiresAt   DateTime            @db.Timestamptz(3)
  usedAt      DateTime?           @db.Timestamptz(3)
  createdAt   DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime            @updatedAt @db.Timestamptz(3)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}
