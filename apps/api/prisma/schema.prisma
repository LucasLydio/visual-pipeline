generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum AuthProvider {
  GITHUB
  GITLAB
  BITBUCKET
  LOCAL
}

enum PasswordResetStatus {
  PENDING
  USED
  EXPIRED
}

enum TeamRole {
  OWNER
  ADMIN
  MAINTAINER
  DEVELOPER
  VIEWER
}

enum SourceProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PipelineStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum DeploymentStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum DeploymentStepStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model User {
  id                String               @id @default(uuid()) @db.Uuid
  email             String               @unique @db.VarChar(320)
  displayName       String               @db.VarChar(120)
  passwordHash      String?              @db.VarChar(255)
  emailVerifiedAt   DateTime?            @db.Timestamptz(3)
  status            UserStatus           @default(ACTIVE)
  lastLoginAt       DateTime?            @db.Timestamptz(3)
  passwordChangedAt DateTime?            @db.Timestamptz(3)
  createdAt         DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @db.Timestamptz(3)
  authAccounts      AuthAccount[]
  sessions          Session[]
  passwordResets    PasswordResetToken[]
  teamMemberships   TeamMember[]
  ownedProjects     Project[]            @relation("ProjectOwner")
  pipelineTemplates PipelineTemplate[]   @relation("PipelineTemplateCreatedBy")
  deployments       Deployment[]         @relation("DeploymentTriggeredBy")
  auditLogs         AuditLog[]

  @@index([status])
}

model AuthAccount {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @db.Uuid
  provider          AuthProvider
  providerAccountId String       @db.VarChar(255)
  username          String?      @db.VarChar(255)
  avatarUrl         String?      @db.Text
  createdAt         DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime     @updatedAt @db.Timestamptz(3)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  accessTokenHash  String    @unique @db.VarChar(128)
  refreshTokenHash String    @unique @db.VarChar(128)
  userAgent        String?   @db.VarChar(512)
  ipAddress        String?   @db.VarChar(64)
  expiresAt        DateTime  @db.Timestamptz(3)
  refreshExpiresAt DateTime  @db.Timestamptz(3)
  revokedAt        DateTime? @db.Timestamptz(3)
  createdAt        DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(3)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([refreshExpiresAt])
}

model PasswordResetToken {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  tokenHash String              @unique @db.VarChar(128)
  status    PasswordResetStatus @default(PENDING)
  expiresAt DateTime            @db.Timestamptz(3)
  usedAt    DateTime?           @db.Timestamptz(3)
  createdAt DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt DateTime            @updatedAt @db.Timestamptz(3)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model Team {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(120)
  slug        String       @unique @db.VarChar(80)
  description String?      @db.VarChar(240)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)
  members     TeamMember[]
  projects    Project[]
  templates   PipelineTemplate[]
  auditLogs   AuditLog[]

  @@index([name])
}

model TeamMember {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String   @db.Uuid
  userId    String   @db.Uuid
  role      TeamRole @default(DEVELOPER)
  title     String?  @db.VarChar(80)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([role])
}

model Project {
  id            String         @id @default(uuid()) @db.Uuid
  teamId        String         @db.Uuid
  ownerId       String?        @db.Uuid
  name          String         @db.VarChar(140)
  slug          String         @db.VarChar(100)
  provider      SourceProvider
  repositoryUrl String         @db.Text
  repositoryId  String?        @db.VarChar(255)
  defaultBranch String         @default("main") @db.VarChar(120)
  status        ProjectStatus  @default(ACTIVE)
  createdAt     DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(3)
  team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  owner         User?          @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  pipelines     Pipeline[]
  deployments   Deployment[]

  @@unique([teamId, slug])
  @@unique([provider, repositoryId])
  @@index([teamId])
  @@index([ownerId])
  @@index([provider])
  @@index([status])
}

model PipelineTemplate {
  id          String                 @id @default(uuid()) @db.Uuid
  teamId      String                 @db.Uuid
  createdById String                 @db.Uuid
  name        String                 @db.VarChar(140)
  description String?                @db.VarChar(240)
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime               @updatedAt @db.Timestamptz(3)
  team        Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdBy   User                   @relation("PipelineTemplateCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  steps       PipelineTemplateStep[]
  pipelines   Pipeline[]

  @@unique([teamId, name])
  @@index([teamId])
  @@index([createdById])
  @@index([isActive])
}

model PipelineTemplateStep {
  id          String           @id @default(uuid()) @db.Uuid
  templateId  String           @db.Uuid
  name        String           @db.VarChar(120)
  description String?          @db.VarChar(240)
  order       Int
  command     String?          @db.Text
  isRequired  Boolean          @default(true)
  isEnabled   Boolean          @default(true)
  createdAt   DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(3)
  template    PipelineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, order])
  @@index([templateId])
}

model Pipeline {
  id          String         @id @default(uuid()) @db.Uuid
  projectId   String         @db.Uuid
  templateId  String?        @db.Uuid
  name        String         @db.VarChar(140)
  description String?        @db.VarChar(240)
  status      PipelineStatus @default(ACTIVE)
  createdAt   DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime       @updatedAt @db.Timestamptz(3)
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template    PipelineTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  steps       PipelineStep[]
  deployments Deployment[]

  @@index([projectId])
  @@index([templateId])
  @@index([status])
}

model PipelineStep {
  id         String   @id @default(uuid()) @db.Uuid
  pipelineId String   @db.Uuid
  name       String   @db.VarChar(120)
  order      Int
  command    String?  @db.Text
  isRequired Boolean  @default(true)
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, order])
  @@index([pipelineId])
}

model Deployment {
  id            String           @id @default(uuid()) @db.Uuid
  projectId     String           @db.Uuid
  pipelineId    String?          @db.Uuid
  triggeredBy   String?          @db.Uuid
  status        DeploymentStatus @default(QUEUED)
  branch        String           @db.VarChar(120)
  commitSha     String?          @db.VarChar(64)
  environment   String           @db.VarChar(80)
  version       String?          @db.VarChar(80)
  queuedAt      DateTime         @default(now()) @db.Timestamptz(3)
  startedAt     DateTime?        @db.Timestamptz(3)
  finishedAt    DateTime?        @db.Timestamptz(3)
  createdAt     DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(3)
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pipeline      Pipeline?        @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  triggeredUser User?            @relation("DeploymentTriggeredBy", fields: [triggeredBy], references: [id], onDelete: SetNull)
  steps         DeploymentStep[]
  logs          DeploymentLog[]

  @@index([projectId])
  @@index([pipelineId])
  @@index([triggeredBy])
  @@index([status])
  @@index([environment])
  @@index([queuedAt])
}

model DeploymentStep {
  id           String               @id @default(uuid()) @db.Uuid
  deploymentId String               @db.Uuid
  name         String               @db.VarChar(120)
  order        Int
  status       DeploymentStepStatus @default(QUEUED)
  startedAt    DateTime?            @db.Timestamptz(3)
  finishedAt   DateTime?            @db.Timestamptz(3)
  createdAt    DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime             @updatedAt @db.Timestamptz(3)
  deployment   Deployment           @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  logs         DeploymentLog[]

  @@unique([deploymentId, order])
  @@index([deploymentId])
  @@index([status])
}

model DeploymentLog {
  id           String          @id @default(uuid()) @db.Uuid
  deploymentId String          @db.Uuid
  stepId       String?         @db.Uuid
  level        LogLevel        @default(INFO)
  message      String          @db.Text
  metadata     Json?
  createdAt    DateTime        @default(now()) @db.Timestamptz(3)
  deployment   Deployment      @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  step         DeploymentStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([deploymentId])
  @@index([stepId])
  @@index([level])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  teamId    String?  @db.Uuid
  userId    String?  @db.Uuid
  action    String   @db.VarChar(120)
  entity    String   @db.VarChar(120)
  entityId  String?  @db.VarChar(120)
  metadata  Json?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}
