{
  "name": "visual-pipeline",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --prefix apps/web run start",
    "dev:api": "npm --prefix apps/api run start:dev",
    "dev:agent": "npm --prefix apps/deploy-agent run start:dev",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
